// Date, Time, and Timestamp: construction, arithmetic, extraction, formatting.

CTL-OPT MAIN(datesDemo);

DCL-PROC datesDemo {
  // Construction via functions — BBK has no date/time/timestamp literals
  DCL-S today  DATE      INZ(date("2026-05-22"));
  DCL-S birth  DATE;
  DCL-S now    TIME;
  DCL-S logTs  TIMESTAMP;

  birth = date("1997-09-23");
  now   = time("14:30:00");
  logTs = timestamp("2026-05-22T14:30:00.000000");

  // Date arithmetic — durations added/subtracted
  DCL-S nextWeek  DATE;
  DCL-S lastMonth DATE;
  DCL-S inOneYear DATE;

  nextWeek  = today + days(7);
  lastMonth = today - months(1);
  inOneYear = today + years(1);

  // Differences between dates
  DCL-S daysOld   INT(10);
  DCL-S yearsOld  INT(10);
  DCL-S monthsOld INT(10);

  daysOld   = diff(today, birth, "days");
  yearsOld  = diff(today, birth, "years");
  monthsOld = diff(today, birth, "months");

  // Extraction of individual components
  DCL-S birthYear  INT(10);
  DCL-S birthMonth INT(10);
  DCL-S birthDay   INT(10);

  birthYear  = subdt(birth, "year");
  birthMonth = subdt(birth, "month");
  birthDay   = subdt(birth, "day");

  // System date/time
  DCL-S systemDate DATE;
  DCL-S systemTime TIME;
  DCL-S systemTs   TIMESTAMP;

  systemDate = currentDate();
  systemTime = currentTime();
  systemTs   = currentTimestamp();

  // Formatting back to string
  DCL-S formatted VARCHAR(20);
  formatted = char(birth, "iso");      // "1997-09-23"
}
